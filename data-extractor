// Multi-date data dump for Sunphotometer
// This code sends a series of dates to the Sunphotometer and prints the received data to Serial Monitor
// Below you habve to set the dates you want to request data for in the dates[] array

const char* dates[] = {
  "10122025",
  "11122025",
  "12122025",
  "15122025",
  "16122025"
};
const int numDates = sizeof(dates) / sizeof(dates[0]);
int currentDate = 0;
unsigned long lastDataTime = 0;
const unsigned long silenceTime = 3000;  // 3 seconds of no data = finished
bool waitingForData = false;
void setup() {
  Serial.begin(9600);
  Serial2.begin(9600);
  sendNextDate();   // Start with first date
}
void loop() {
  // Read incoming data
  if (Serial2.available()) {
    char c = Serial2.read();
    Serial.write(c);
    lastDataTime = millis();   // Reset silence timer
    waitingForData = true;
  }
  // If data stopped arriving → send next date
  if (waitingForData && millis() - lastDataTime > silenceTime) {
    waitingForData = false;
    sendNextDate();
  }
}
void sendNextDate() {
  if (currentDate < numDates) {
    Serial2.print("DATA");
    Serial2.println(dates[currentDate]);
    Serial.print("\nRequesting date: ");
    Serial.println(dates[currentDate]);
    currentDate++;
  } else {
    Serial.println("\nAll dates completed.");
  }
}